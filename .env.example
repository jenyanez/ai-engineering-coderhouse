# === Variables de Entorno del Proyecto ===
# Copia este archivo como .env y reemplaza los valores con tus claves reales.
# NUNCA subas el archivo .env a GitHub.

# OpenAI
OPENAI_API_KEY=TU_API_KEY_AQUI

# Anthropic
ANTHROPIC_API_KEY=TU_API_KEY_AQUI

# Pinecone (Módulo 4)
PINECONE_API_KEY=TU_API_KEY_AQUI
PINECONE_ENVIRONMENT=TU_ENVIRONMENT_AQUI

# LangSmith (Módulo 7 - Observabilidad)
LANGCHAIN_API_KEY=TU_API_KEY_AQUI
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-engineering-coderhouse
